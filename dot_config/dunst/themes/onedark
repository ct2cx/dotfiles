[urgency_critical]
background = "#e86671"
foreground = "#282c34"
highlight = "#282c34"
format = "<span color='#282c34'>%a</span>\n<b>%s</b>\n%b"

[urgency_normal]
background = "#61afef"
foreground = "#282c34"
highlight = "#282c34"
format = "<span color='#282c34'>%a</span>\n<b>%s</b>\n%b"
timeout = 10

[urgency_low]
background = "#5c6370"
foreground = "#282c34"
highlight = "#282c34"
format = "<span color='#282c34'>%a</span>\n<b>%s</b>\n%b"
timeout = 5
